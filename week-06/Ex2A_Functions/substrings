    "def parse_and_display2(name):\n",
    "    parts = name.split()\n",
    "\n",
    "    print(f\"Full name: {name}\")\n",
    "\n",
    "    if len(parts) == 1:\n",
    "        print(f\"First name: {parts[0]}\")\n",
    "        print(\"Middle name: None\")\n",
    "        print(\"Last name: None\")\n",
    "\n",
    "    elif len(parts) == 2:\n",
    "        print(f\"First name: {parts[0]}\")\n",
    "        print(\"Middle name: None\")\n",
    "        print(f\"Last name: {parts[1]}\")\n",
    "\n",
    "    elif len(parts) == 3:\n",
    "        print(f\"First name: {parts[0]}\")\n",
    "        print(f\"Middle name: {parts[1]}\")\n",
    "        print(f\"Last name: {parts[2]}\")\n",
    "\n",
    "    else:\n",
    "        print(\"Name has more than 3 words\")\n",
    "        # Tests\n",

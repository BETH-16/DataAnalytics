   "source": [
    "def parse_and_display(name):\n",
    "    for i in range(len(name)):\n",
    "        if name[i] == ' ':\n",
    "            first = name[:i]\n",
    "            last = name[i+1:]\n",
    "            break\n",
    "\n",
    "    print(f\"Full name: {name}\")\n",
    "    print(f\"First name: {first}\")\n",
    "    print(f\"Last name: {last}\")\n",
    "\n",
    "test_name = \"John Doe\"\n",
    "parse_and_display(test_name)"
   ]
